    "Are you sure you want to logout?" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد تسجيل الخروج"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sind Sie sicher?"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres cerrar sesión?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir vous déconnecter ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "È sicuro di voler continuare?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ログアウトしてもよろしいですか?"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "정말로 로그아웃하시겠습니까?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet u zeker dat u wilt uitloggen?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza que deseja sair?"
          }
        }
      }
    },
